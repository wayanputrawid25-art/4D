# ForexOS Environment Variables
# Copy this file to .env for each environment
# DO NOT commit .env files to version control

# =============================================================================
# SHARED (All Applications)
# =============================================================================

# Node Environment
NODE_ENV=development

# =============================================================================
# DATABASE (Backend + Robot)
# =============================================================================
# Neon PostgreSQL Connection String
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# =============================================================================
# AUTHENTICATION (Backend Only)
# =============================================================================
# JWT Secret - Min 32 characters, keep secret!
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-chars

# Token Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# =============================================================================
# ENCRYPTION (Backend Only)
# =============================================================================
# 32-byte encryption key for sensitive data
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# =============================================================================
# API CONFIGURATION (Backend)
# =============================================================================
# Server
PORT=3001

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# =============================================================================
# REDIS (Backend + Robot)
# =============================================================================
REDIS_URL=rediss://user:password@host.redis.cloud:6379

# =============================================================================
# ROBOT API (Backend)
# =============================================================================
ROBOT_API_URL=http://localhost:8000
ROBOT_API_KEY=your-robot-api-key

# =============================================================================
# MT5 CONFIGURATION (Robot Only)
# =============================================================================
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=ICMarkets-Demo
MT5_BRIDGE_HOST=localhost
MT5_BRIDGE_PORT=8888
MT5_USE_DEMO=true
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# =============================================================================
# FRONTEND (Public Variables - Safe to Expose)
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_ENV=development
